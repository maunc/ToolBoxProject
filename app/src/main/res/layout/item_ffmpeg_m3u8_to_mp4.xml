<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <RelativeLayout
        android:id="@+id/item_ffmpeg_mp4_to_mp3_root_layout"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_110"
        android:layout_marginVertical="@dimen/dp_5">

        <androidx.cardview.widget.CardView
            android:id="@+id/item_ffmpeg_mp4_to_mp3_file_image_card"
            android:layout_width="@dimen/dp_80"
            android:layout_height="@dimen/dp_80"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/dp_10"
            app:cardCornerRadius="@dimen/dp_12">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/item_ffmpeg_mp4_to_mp3_file_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop" />
        </androidx.cardview.widget.CardView>

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/dp_8"
            android:layout_toEndOf="@+id/item_ffmpeg_mp4_to_mp3_file_image_card"
            android:orientation="vertical"
            tools:ignore="RelativeOverlap">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/item_ffmpeg_mp4_to_mp3_file_title_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:singleLine="true"
                android:textColor="@color/black"
                android:textSize="22sp"
                tools:text="@string/functions_are_under_development" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/item_ffmpeg_mp4_to_mp3_ts_segment_size_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_5"
                android:background="@drawable/bg_white_stroke_gray_radius_12"
                android:padding="@dimen/dp_5"
                android:textColor="@color/black"
                android:textSize="12sp"
                tools:text="@string/functions_are_under_development" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/item_ffmpeg_mp4_to_mp3_file_size_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:singleLine="true"
                android:textColor="@color/black"
                android:textSize="12sp"
                android:layout_marginTop="@dimen/dp_5"
                tools:text="@string/functions_are_under_development" />
        </androidx.appcompat.widget.LinearLayoutCompat>

        <androidx.appcompat.widget.LinearLayoutCompat
            android:id="@+id/item_ffmpeg_mp4_to_mp3_convert_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="@dimen/dp_15"
            android:orientation="vertical"
            tools:ignore="RelativeOverlap">

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="@dimen/dp_35"
                android:layout_height="@dimen/dp_35"
                android:src="@drawable/icon_ffmpeg_convert" />

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="@string/ffmpeg_item_convert_text"
                android:textColor="@color/black"
                android:textSize="12sp" />
        </androidx.appcompat.widget.LinearLayoutCompat>
    </RelativeLayout>
</layout>