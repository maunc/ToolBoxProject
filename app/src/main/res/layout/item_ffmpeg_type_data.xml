<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="@dimen/dp_5">

        <RelativeLayout
            android:id="@+id/item_ffmpeg_type_tab"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_80">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/item_ffmpeg_type_type_tv"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="@dimen/dp_30"
                android:gravity="center_vertical"
                android:textColor="@color/black"
                android:textSize="22sp"
                tools:ignore="RelativeOverlap" />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/item_ffmpeg_type_expand_iv"
                android:layout_width="@dimen/dp_30"
                android:layout_height="@dimen/dp_30"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="@dimen/dp_15"
                android:src="@drawable/icon_group_expand_no" />
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/item_ffmpeg_type_more_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/item_ffmpeg_type_tab"
            android:visibility="gone"
            tools:visibility="visible" />
    </RelativeLayout>
</layout>