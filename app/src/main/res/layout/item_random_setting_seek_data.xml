<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="@dimen/dp_5">

    <RelativeLayout
        android:id="@+id/item_random_setting_tab"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_80">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/item_random_setting_type_tv"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginStart="@dimen/dp_30"
            android:gravity="center_vertical"
            android:textColor="@color/black"
            android:textSize="22sp"
            tools:ignore="RelativeOverlap" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/item_random_setting_expand_iv"
            android:layout_width="@dimen/dp_30"
            android:layout_height="@dimen/dp_30"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="@dimen/dp_15"
            android:src="@drawable/icon_group_expand_no" />
    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/item_random_setting_more_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/item_random_setting_tab"
        android:visibility="gone"
        tools:visibility="visible">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/item_random_setting_size_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_30"
            android:layout_marginTop="@dimen/dp_5"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="结果文本大小:30" />

        <SeekBar
            android:id="@+id/item_random_setting_seek"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_40"
            android:layout_below="@id/item_random_setting_size_tv"
            android:layout_marginHorizontal="@dimen/dp_20"
            android:layout_marginTop="@dimen/dp_5"
            android:progressBackgroundTint="@color/alpha_seek"
            android:progressTint="@color/black"
            android:thumbTint="@color/black" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/item_random_setting_tips_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/item_random_setting_seek"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="@dimen/dp_5"
            android:textSize="16sp"
            android:text="@string/random_setting_result_text_size_tips_text"
            android:textColor="@color/red" />
    </RelativeLayout>
</RelativeLayout>