<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data>

    </data>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/ftp_server_controller_status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="@dimen/dp_60"
            android:gravity="center"
            android:textColor="@color/black"
            android:textSize="26sp" />

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true"
            android:layout_marginBottom="@dimen/dp_50"
            android:orientation="vertical">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/ftp_server_controller_tv"
                android:layout_width="@dimen/dp_260"
                android:layout_height="wrap_content"
                android:background="@drawable/common_control_button_bg"
                android:gravity="center"
                android:paddingHorizontal="@dimen/dp_10"
                android:paddingVertical="@dimen/dp_15"
                android:text="@string/ftp_server_connect_text"
                android:textColor="@color/black"
                android:textSize="26sp" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/ftp_server_config_tv"
                android:layout_width="@dimen/dp_260"
                android:layout_height="wrap_content"
                android:layout_below="@id/ftp_server_controller_tv"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="@dimen/dp_30"
                android:background="@drawable/common_control_button_bg"
                android:gravity="center"
                android:paddingHorizontal="@dimen/dp_10"
                android:paddingVertical="@dimen/dp_15"
                android:text="@string/ftp_main_config_text"
                android:textColor="@color/black"
                android:textSize="26sp" />
        </androidx.appcompat.widget.LinearLayoutCompat>

    </RelativeLayout>
</layout>