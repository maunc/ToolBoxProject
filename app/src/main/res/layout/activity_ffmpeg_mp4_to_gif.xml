<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="ffmpegMp4ToGifViewModel"
            type="com.maunc.toolbox.ffmpeg.viewmodel.FFmpegMp4ToGifViewModel" />

        <import type="android.view.View" />
    </data>

    <RelativeLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ffmpeg.ui.FFmpegMp4ToGifActivity">

        <include
            android:id="@+id/common_tool_bar"
            layout="@layout/layout_tool_bar_common" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/common_tool_bar"
            android:layout_centerHorizontal="true">

            <com.maunc.videoplayer.CustomVideoPlayer
                android:id="@+id/ffmpeg_mp4_to_gif_video_player"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_260"
                android:layout_marginTop="@dimen/dp_10"
                android:background="@drawable/stroke_black_bg_white_radius_12"
                android:visibility="@{ffmpegMp4ToGifViewModel.currentSelectMp4File==null?View.GONE:View.VISIBLE}" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/ffmpeg_mp4_to_gif_target_file_msg_recycler"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_130"
                android:layout_below="@id/ffmpeg_mp4_to_gif_video_player"
                android:layout_marginHorizontal="@dimen/dp_10"
                android:layout_marginTop="@dimen/dp_10"
                android:background="@drawable/stroke_black_bg_white_radius_12"
                android:padding="@dimen/dp_10"
                android:visibility="@{ffmpegMp4ToGifViewModel.currentSelectMp4File==null?View.GONE:View.VISIBLE}" />

            <androidx.appcompat.widget.LinearLayoutCompat
                android:id="@+id/ffmpeg_mp4_to_gif_clip_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/ffmpeg_mp4_to_gif_target_file_msg_recycler"
                android:layout_marginHorizontal="@dimen/dp_10"
                android:layout_marginTop="@dimen/dp_10"
                android:background="@drawable/stroke_black_bg_white_radius_12"
                android:orientation="vertical"
                android:padding="@dimen/dp_10"
                android:visibility="@{ffmpegMp4ToGifViewModel.currentSelectMp4File==null?View.GONE:View.VISIBLE}">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/ffmpeg_mp4_to_gif_clip_title_tv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/ffmpeg_mp4_to_gif_clip_title_tv"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/ffmpeg_mp4_to_gif_clip_start_tv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_6"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    tools:text="开始时间: 00:00" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/ffmpeg_mp4_to_gif_clip_end_tv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    tools:text="结束时间: 00:10" />

                <com.google.android.material.slider.RangeSlider
                    android:id="@+id/ffmpeg_mp4_to_gif_clip_range_seek"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_40"
                    android:valueFrom="0"
                    android:valueTo="100"
                    app:haloColor="@color/alpha_seek"
                    app:thumbColor="@color/black"
                    app:tickVisible="false"
                    app:trackColorActive="@color/black"
                    app:trackColorInactive="@color/alpha_seek" />
            </androidx.appcompat.widget.LinearLayoutCompat>

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/ffmpeg_mp4_to_gif_not_file_tips"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_180"
                android:layout_marginHorizontal="@dimen/dp_15"
                android:layout_marginTop="@dimen/dp_10"
                android:gravity="center"
                android:text="@string/ffmpeg_mp4_to_gif_not_file_tips_tv"
                android:textColor="@color/black"
                android:textSize="36sp"
                android:visibility="@{ffmpegMp4ToGifViewModel.currentSelectMp4File==null?View.VISIBLE:View.GONE}" />

            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_centerHorizontal="true"
                android:layout_marginBottom="@dimen/dp_20"
                android:orientation="vertical">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/ffmpeg_mp4_to_gif_select_mp4_file_tv"
                    android:layout_width="@dimen/dp_260"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:background="@drawable/common_control_button_bg"
                    android:gravity="center"
                    android:paddingVertical="@dimen/dp_15"
                    android:text="@string/ffmpeg_mp4_to_gif_click_tv"
                    android:textColor="@color/black"
                    android:textSize="26sp" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/ffmpeg_mp4_to_gif_handle_mp4_file_to_tv"
                    android:layout_width="@dimen/dp_260"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="@dimen/dp_15"
                    android:background="@drawable/common_control_button_bg"
                    android:gravity="center"
                    android:paddingVertical="@dimen/dp_15"
                    android:text="@string/ffmpeg_mp4_to_gif_handle_click_tv"
                    android:textColor="@color/black"
                    android:textSize="26sp" />
            </androidx.appcompat.widget.LinearLayoutCompat>
        </RelativeLayout>
    </RelativeLayout>
</layout>

