<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="ffmpegH265OrH264ToMp4ViewModel"
            type="com.maunc.toolbox.ffmpeg.viewmodel.FFmpegH265OrH264ToMp4ViewModel" />
        <import type="android.view.View" />
    </data>

    <RelativeLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ffmpeg.ui.FFmpegH265OrH264ToMp4Activity">

        <include
            android:id="@+id/common_tool_bar"
            layout="@layout/layout_tool_bar_common" />

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:handleNotDataLayout="@{ffmpegH265OrH264ToMp4ViewModel.resultList}" />

        <com.scwang.smart.refresh.layout.SmartRefreshLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/common_tool_bar">

            <com.scwang.smart.refresh.header.FalsifyHeader
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/ffmpeg_h265_or_h264_to_mp4_recycler"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="@{ffmpegH265OrH264ToMp4ViewModel.isExistFile?View.VISIBLE:View.GONE}"/>

            <com.scwang.smart.refresh.header.FalsifyFooter
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </com.scwang.smart.refresh.layout.SmartRefreshLayout>
    </RelativeLayout>
</layout>